{
  "name": "comstruct",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @comstruct/api\" \"npm run dev --workspace @comstruct/web\"",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.9.3"
  }
}

